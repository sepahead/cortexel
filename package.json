{
  "name": "cortexel",
  "version": "0.10.0-dev.0",
  "private": true,
  "description": "Versioned, provenance-first scientific figure contracts and deterministic SVG rendering for neural-simulation data and AI agents.",
  "license": "MIT",
  "author": "Sepehr Mahmoudian",
  "homepage": "https://github.com/sepahead/cortexel#readme",
  "bugs": "https://github.com/sepahead/cortexel/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sepahead/cortexel.git"
  },
  "type": "module",
  "packageManager": "bun@1.3.14",
  "sideEffects": false,
  "keywords": [
    "visualization",
    "neuroscience",
    "neural-network",
    "three",
    "react-three-fiber",
    "agent",
    "llm",
    "webgl",
    "spiking-neural-network",
    "nest"
  ],
  "files": [
    "dist",
    "README.md",
    "AGENTS.md",
    "CLAUDE.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md",
    "LICENSES",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./core": {
      "import": {
        "types": "./dist/core/index.d.ts",
        "default": "./dist/core/index.js"
      },
      "require": {
        "types": "./dist/core/index.d.cts",
        "default": "./dist/core/index.cjs"
      }
    },
    "./figure": {
      "import": {
        "types": "./dist/figure/index.d.ts",
        "default": "./dist/figure/index.js"
      },
      "require": {
        "types": "./dist/figure/index.d.cts",
        "default": "./dist/figure/index.cjs"
      }
    },
    "./render-svg": {
      "import": {
        "types": "./dist/render-svg/index.d.ts",
        "default": "./dist/render-svg/index.js"
      },
      "require": {
        "types": "./dist/render-svg/index.d.cts",
        "default": "./dist/render-svg/index.cjs"
      }
    },
    "./adapters/nest": {
      "import": {
        "types": "./dist/adapters/nest/index.d.ts",
        "default": "./dist/adapters/nest/index.js"
      },
      "require": {
        "types": "./dist/adapters/nest/index.d.cts",
        "default": "./dist/adapters/nest/index.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react/index.d.ts",
        "default": "./dist/react/index.js"
      },
      "require": {
        "types": "./dist/react/index.d.cts",
        "default": "./dist/react/index.cjs"
      }
    },
    "./react/charts": {
      "import": {
        "types": "./dist/react/charts.d.ts",
        "default": "./dist/react/charts.js"
      },
      "require": {
        "types": "./dist/react/charts.d.cts",
        "default": "./dist/react/charts.cjs"
      }
    },
    "./react/knowledge-graph": {
      "import": {
        "types": "./dist/react/knowledge-graph.d.ts",
        "default": "./dist/react/knowledge-graph.js"
      },
      "require": {
        "types": "./dist/react/knowledge-graph.d.cts",
        "default": "./dist/react/knowledge-graph.cjs"
      }
    },
    "./skills.manifest.json": "./dist/skills.manifest.json",
    "./contract/manifest.json": "./dist/contract/manifest.v1.json",
    "./contract/*": "./dist/contract/*",
    "./package.json": "./package.json"
  },
  "imports": {
    "#cortexel-request-capability": "./dist/internal/request-capability.cjs"
  },
  "bin": {
    "cortexel": "./dist/cli/main.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "bun run check:generated && tsup && tsx scripts/prepare-package.ts && tsx scripts/emit-manifest.ts && tsx scripts/finalize-package.ts",
    "manifest": "tsx scripts/emit-manifest.ts",
    "generate": "tsx scripts/generate-contract.ts",
    "check:generated": "tsx scripts/check-generated.ts",
    "check:formal": "lean formal/WeightRowSaturation.lean",
    "typecheck": "tsc --noEmit",
    "check:ledger": "tsx scripts/check-evidence-ledger.ts",
    "release:verify": "tsx scripts/verify-release.ts",
    "test": "vitest run --no-file-parallelism --testTimeout=30000",
    "test:watch": "vitest",
    "check": "bun run check:generated && tsc --noEmit && bun run test",
    "audit": "bun audit",
    "lint:package": "publint",
    "test:package": "bun scripts/smoke-package.ts",
    "test:python": "python -m unittest discover -s python/tests",
    "check:python": "mypy --config-file python/pyproject.toml python/src/cortexel && ruff check python/src python/tests scripts/smoke-python-package.py && python -m compileall -q python/src python/tests scripts/smoke-python-package.py",
    "test:python-package": "python scripts/smoke-python-package.py",
    "prepublishOnly": "bun run release:verify && bun run check:ledger && bun run build && bun run check && bun run test:python && bun run check:python && bun run test:python-package && bun run audit && bun run lint:package && bun run test:package && bun run release:verify"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "zod": "^4"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "fast-uri": "3.1.4"
  },
  "peerDependencies": {
    "@types/react": "^19",
    "@types/three": ">=0.184 <0.186",
    "react": "^19",
    "react-dom": "^19",
    "three": ">=0.184 <0.186",
    "@react-three/fiber": "^9.6",
    "d3-force-3d": "^3.0.5"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    },
    "@types/three": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "three": {
      "optional": true
    },
    "@react-three/fiber": {
      "optional": true
    },
    "d3-force-3d": {
      "optional": true
    }
  },
  "_peerNote": "ajv and zod are normal dependencies: `cortexel/figure` compiles the packaged JSON Schemas with Ajv, while the legacy `cortexel/core` VizSpec contract uses zod. `cortexel/figure`, `cortexel/render-svg`, and `cortexel/adapters/nest` load no React/Three/R3F/D3 peer. react is the only runtime peer used by `cortexel/react/charts`; react/react-dom/three/@react-three/fiber are optional runtime peers needed by `cortexel/react`; @types/react/@types/three are optional declaration peers for TypeScript consumers; d3-force-3d is needed only by `cortexel/react/knowledge-graph`.",
  "devDependencies": {
    "@react-three/fiber": "^9.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-test-renderer": "^19.0.0",
    "@types/three": "^0.185.1",
    "d3-force-3d": "^3.0.5",
    "fast-check": "^4.9.0",
    "publint": "^0.3.15",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-test-renderer": "^19.0.0",
    "three": "^0.185.1",
    "tsup": "^8.3.0",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": "^22.0.0 || ^24.0.0 || ^26.0.0"
  }
}
