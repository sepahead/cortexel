{
  "name": "cortexel",
  "version": "0.4.0",
  "description": "Agent-consumable scientific-visualization library for neural simulations. Emit a declarative VizSpec; render spike rasters, Brunel networks, STDP curves and more, with scientific-honesty provenance enforced fail-closed.",
  "license": "MIT",
  "author": "Sepehr Mahmoudian",
  "homepage": "https://github.com/sepahead/cortexel#readme",
  "bugs": "https://github.com/sepahead/cortexel/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sepahead/cortexel.git"
  },
  "type": "module",
  "sideEffects": false,
  "keywords": [
    "visualization",
    "neuroscience",
    "neural-network",
    "three",
    "react-three-fiber",
    "agent",
    "llm",
    "webgl",
    "spiking-neural-network",
    "nest"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup && tsx scripts/emit-manifest.ts",
    "manifest": "tsx scripts/emit-manifest.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "tsc --noEmit && vitest run",
    "prepublishOnly": "npm run check && npm run build"
  },
  "peerDependencies": {
    "react": "^19",
    "three": "^0.184",
    "@react-three/fiber": "^9.6",
    "@react-three/drei": "^10.7",
    "zod": "^4"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "three": {
      "optional": true
    },
    "@react-three/fiber": {
      "optional": true
    },
    "@react-three/drei": {
      "optional": true
    }
  },
  "_peerNote": "zod is required (the `cortexel/core` VizSpec contract needs it at runtime). react/three/@react-three/* are optional peers — only the `cortexel/react` entry needs them; `cortexel/core` is dependency-free beyond zod.",
  "devDependencies": {
    "@react-three/drei": "^10.7.0",
    "@react-three/fiber": "^9.6.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.0.0",
    "@types/three": "^0.184.0",
    "react": "^19.0.0",
    "three": "^0.184.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "zod": "^4.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
