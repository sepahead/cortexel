{
  "registry": "cortexel-capabilities",
  "version": "1.0",
  "description": "Every capability Cortexel exposes, with exactly one status. This is what makes the stable/experimental boundary enforceable instead of rhetorical.\n\n`status` is a promise. `releaseReady` is whether the evidence for that promise actually exists. They are deliberately separate fields, because a label that can be set without evidence is a marketing label.",

  "statuses": {
    "stable": "Covered by the contract, the determinism promise, the accessibility profile, and the compatibility policy. Cortexel owns the complete output path end to end.",
    "experimental": "Available, versioned independently, and explicitly NOT covered by any of the above. Absent from stable counts, default discovery, root exports, and the conformance badge.",
    "deprecated": "Still present, scheduled for removal, with a named replacement.",
    "removed": "Gone. Has a deterministic migration outcome — never a silent alias, because a silent alias makes a stored artifact ambiguous about what was actually validated."
  },

  "capabilities": [
    { "id": "neuro.analog_trace",            "kind": "skill", "status": "stable", "renderer": "figure.analog_trace",            "determinismClass": "deterministic_svg", "exportClass": "svg+table+sidecar", "requiredPeers": [], "owner": "Sepehr Mahmoudian" },
    { "id": "neuro.spike_raster",            "kind": "skill", "status": "stable", "renderer": "figure.spike_raster",            "determinismClass": "deterministic_svg", "exportClass": "svg+table+sidecar", "requiredPeers": [], "owner": "Sepehr Mahmoudian" },
    { "id": "neuro.population_rate",         "kind": "skill", "status": "stable", "renderer": "figure.population_rate",         "determinismClass": "deterministic_svg", "exportClass": "svg+table+sidecar", "requiredPeers": [], "owner": "Sepehr Mahmoudian" },
    { "id": "neuro.response_curve",          "kind": "skill", "status": "stable", "renderer": "figure.response_curve",          "determinismClass": "deterministic_svg", "exportClass": "svg+table+sidecar", "requiredPeers": [], "owner": "Sepehr Mahmoudian" },
    { "id": "neuro.isi_distribution",        "kind": "skill", "status": "stable", "renderer": "figure.distribution",            "determinismClass": "deterministic_svg", "exportClass": "svg+table+sidecar", "requiredPeers": [], "owner": "Sepehr Mahmoudian" },
    { "id": "neuro.psth",                    "kind": "skill", "status": "stable", "renderer": "figure.psth",                    "determinismClass": "deterministic_svg", "exportClass": "svg+table+sidecar", "requiredPeers": [], "owner": "Sepehr Mahmoudian" },
